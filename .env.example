# ── X (Twitter) API ──────────────────────────────────────────────────────────
# Get these from: https://developer.twitter.com → Your App → Keys and Tokens
# App must have "Read" permissions and OAuth 2.0 enabled

X_CLIENT_ID=your_oauth2_client_id_here
X_CLIENT_SECRET=your_oauth2_client_secret_here

# Run `npm run auth` to get these two values:
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=

# Your numeric user ID — find it at: https://tweeterid.com
X_USER_ID=your_numeric_user_id_here

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Pipeline Config ───────────────────────────────────────────────────────────
# X free tier allows 1 req/15min on bookmarks endpoint
POLL_INTERVAL_MINUTES=15

# Only process bookmarks containing this keyword/emoji
# Set to empty string "" to process ALL new bookmarks
FILTER_KEYWORD=🎬

# Local API server port (for dashboard)
PORT=8787
